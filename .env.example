NODE_ENV=development
PORT=3000

FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=railway

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ALLOW_PUBLIC_REGISTER=false

# En producción (Railway): true recomendado para validar ventanas de vacunas
VACCINATION_ENFORCE_APPLICATION_WINDOW=false

# Railway MySQL (alternativa a DB_*; se usan si DB_HOST no está definido)
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
# DB_SSL=true
