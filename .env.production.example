NODE_ENV=production
PORT=3000

FRONTEND_URL=https://tu-app.vercel.app

# Railway: NO pegues contraseñas. Usá Variable Reference desde el servicio MySQL:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQL_PUBLIC_URL
# El backend prueba red privada y, si falla, usa MYSQL_PUBLIC_URL con SSL automático.

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ALLOW_PUBLIC_REGISTER=false
VACCINATION_ENFORCE_APPLICATION_WINDOW=true

# Opcional: forzar SSL manualmente (normalmente no hace falta)
# DB_SSL=true
