NODE_ENV=production
PORT=3000

# URL exacta del frontend en Vercel (sin barra final). Varias separadas por coma si hace falta.
FRONTEND_URL=https://tu-app.vercel.app

# MySQL — Railway inyecta MYSQL* al vincular el servicio; también podés usar DB_* manualmente
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=railway

# Si usás el endpoint público de MySQL en Railway, activá SSL:
# DB_SSL=true

# Secretos largos (generá con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seguridad
ALLOW_PUBLIC_REGISTER=false
VACCINATION_ENFORCE_APPLICATION_WINDOW=true
